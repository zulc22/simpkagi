include mixins-g200x

html
    head 
        title Kagi Search: #{query}
        style.
            <!--
            body,td,div,.p,a{font-family:arial,sans-serif }
            div,td{color:#000}
            .f,.fl:link{color:#6f6f6f}
            a:link,.w,a.w:link,.w a:link{color:#00c}
            a:visited,.fl:visited{color:#551a8b}
            a:active,.fl:active{color:#f00}
            .t a:link,.t a:active,.t a:visited,.t{color:#ffffff}
            .t{background-color:#fcb319}
            .h{color:#3366cc}
            .i,.i:link{color:#a90a08}
            .a,.a:link{color:#008000}
            .z{display:none}
            div.n {margin-top: 1ex}
            .n a{font-size:10pt; color:#000}
            .n .i{font-size:10pt; font-weight:bold}
            .q a:visited,.q a:link,.q a:active,.q {color: #00c; text-decoration: none;}
            .b{font-size: 12pt; color:#00c; font-weight:bold}
            .ch{cursor:pointer;cursor:hand}
            .e{margin-top: .75em; margin-bottom: .75em}
            .g{margin-top: 1em; margin-bottom: 1em}
            //-->
        script.
            <!--
            function ss(w){window.status=w;return true;}
            function cs(){window.status='';}
            function ga(o,e) {return true;}
            //-->
    body(bgcolor="#ffffff")
        table(border=0 cellpadding=0 cellspacing=0)
            tr 
                td(rowspan=3 valign="top")
                    a(href="/")
                        img(src="/images/web_logo_left.gif" width=200 height=76
                        alt="Go to Kagi Home" border=0)
                //- td(nowrap)
                //-     font(size=-1)
                //-         a(href="/advanced_search") Advanced Search
                //-         br
                //-         | &nbsp;&nbsp;&nbsp;&nbsp;
                //-         a(href="/preferences") Preferences
                //-         br
                //-         | &nbsp;&nbsp;&nbsp;&nbsp;
                //-         a(href="/language_tools") Language Tools
                //-         br
                //-         | &nbsp;&nbsp;&nbsp;&nbsp;
                //-         a(href="/help") Search Tips
            tr
                td(valign="middle")
                    form(name="gs" method="GET" action="/search")
                        //- input(type="hidden" name="hl" value="en")
                        input(type="text" name="q" size="31" maxlength="2048" value=query)
                        font(size=-1)
                            input(type="submit" name="btnK" value="Kagi Search")
                            span#hf
            tr
                td
                    font(size=-1)!= results_message
        br
        div#r
            each r in results
                +result(r, query)
        center 
            p
                +kaaagi
            hr.z
            table(width="100%" cellpadding=2 cellspacing=0 border=0)
                tr 
                    td.t(align="center")
                        font(size=-1)
                            a(href="/") Kagi Home
                            != " - "
                            a(href=searchinfo.share_url) Sharable permalink to these results
                            //- | -
                            //- a(href="/ads") Advertise with Us
                            //- | -
                            //- a(href="/services") Buisness Solutions
                            //- | -
                            //- a(href="/options") Services &amp; Tools
                            //- | -
                            //- a(href="/about.html") Jobs, Press, Help 
            br
            font.p(size=-1)
                | &copy;#{new Date().getFullYear()} Kagi. Humanize the Web.